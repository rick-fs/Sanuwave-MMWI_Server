+/*
+ * SANUWAVE: RP1 RIO register access for atomic multi-pin GPIO writes.
+ *
+ * The RP1 chip exposes a Register Input/Output (RIO) block where a single
+ * 32-bit write can flip multiple pins on the same bus cycle, eliminating
+ * inter-pin skew that occurs when calling gpio_set_value() in a loop.
+ *
+ * RP1 has three GPIO banks:
+ *   Bank 0: GPIO 0..27   (the 40-pin header pins)  rio_offset = 0x0000
+ *   Bank 1: GPIO 28..33                            rio_offset = 0x4000
+ *   Bank 2: GPIO 34..53                            rio_offset = 0x8000
+ *
+ * Within each bank, RIO_OUT is at offset 0x00. Writes to set/clear bits go
+ * through address aliases at +0x2000 (set) and +0x3000 (clear) from the
+ * RIO base, which is the rw1s/rw1c access pattern used by RP1.
+ *
+ * This driver only supports atomic writes for pins within a single bank,
+ * and since all 40-pin-header pins live in bank 0, that's the only bank
+ * the fast path handles. Pins outside bank 0 fall back to per-pin
+ * gpio_set_value().
+ *
+ * Constants below are derived from drivers/pinctrl/pinctrl-rp1.c:
+ *   - RP1_RIO_OUT       (0x00)   register offset within a bank
+ *   - RP1_SET_OFFSET    (0x2000) alias for atomic bit-set
+ *   - RP1_CLR_OFFSET    (0x3000) alias for atomic bit-clear
+ *   - rp1_iobanks[0]    rio_offset = 0x0000 for bank 0
+ *
+ * The RIO physical base address is not hardcoded; it is looked up at
+ * runtime via the device tree node with compatible "raspberrypi,rp1-gpio"
+ * (resource index 1).
+ */
+#define RP1_BANK0_NUM_GPIOS	28
+#define RP1_BANK0_RIO_OFFSET	0x0000
+#define RP1_RIO_OUT_REG		0x00
+#define RP1_RIO_SET_ALIAS	0x2000
+#define RP1_RIO_CLR_ALIAS	0x3000
+#define RP1_RIO_REGION_SIZE	0x4000	/* covers RW + XOR + SET + CLR aliases */
+
