+/*
+ * Recompute the bitmask used by the atomic-write fast path, and lazily
+ * acquire the RIO register mapping the first time it's needed. Called
+ * from strobe_gpio_store() after GPIOs have been requested.
+ *
+ * The fast path is only enabled when all configured pins are in RP1
+ * bank 0 (GPIO 0..27, the 40-pin header pins). Pins in banks 1 or 2
+ * disable the fast path; the ISR falls back to per-pin gpio_set_value().
+ *
+ * The RIO base address is looked up from the device tree by finding the
+ * "raspberrypi,rp1-gpio" node and reading its second resource (which is
+ * the RIO block per pinctrl-rp1.c). This avoids hardcoding a physical
+ * address that could shift between RP1 revisions or board variants.
+ *
+ * Caller must hold no spinlocks (ioremap and DT walks may sleep).
+ */
+static void sanuwave_strobe_rebuild_mask(struct cfe_device *cfe,
+					 struct device *dev)
+{
+	struct device_node *rp1_gpio_node;
+	struct resource res;
+	int i, ret;
+	u32 mask = 0;
+
+	for (i = 0; i < cfe->strobe_gpio_count; i++) {
+		int g = cfe->strobe_gpios[i];
+		struct gpio_chip *gc;
+		int local;
+
+		if (g < 0)
+			continue;
+
+		/*
+		 * Userspace passes Linux global GPIO numbers (e.g. 586 for
+		 * BCM GPIO17 on Pi 5, where the RP1 chip has base 569). The
+		 * RP1 RIO register is indexed by chip-local pin numbers, so
+		 * we have to subtract the chip's base before OR'ing into
+		 * the mask. Without this conversion, BIT(g) for g >= 32
+		 * shifts past the end of a 32-bit register and we'd write
+		 * a zero mask.
+		 *
+		 * The legacy gpio_to_chip() helper has been removed in
+		 * recent kernels; the documented path is to convert the
+		 * integer GPIO to a descriptor first, then ask the
+		 * descriptor for its chip.
+		 */
+		gc = gpiod_to_chip(gpio_to_desc(g));
+		if (!gc) {
+			dev_warn(dev,
+				 "SANUWAVE: GPIO %d has no gpiochip — atomic write disabled, using per-pin fallback\n",
+				 g);
+			cfe->strobe_set_mask = 0;
+			return;
+		}
+
+		local = g - gc->base;
+		if (local < 0 || local >= RP1_BANK0_NUM_GPIOS) {
+			dev_warn(dev,
+				 "SANUWAVE: GPIO %d (local %d on chip base %d) outside bank 0 (0..%d) — atomic write disabled, using per-pin fallback\n",
+				 g, local, gc->base, RP1_BANK0_NUM_GPIOS - 1);
+			cfe->strobe_set_mask = 0;
+			return;
+		}
+
+		mask |= BIT(local);
+	}
+
+	cfe->strobe_set_mask = mask;
+
+	if (!mask || cfe->strobe_rio_base)
+		return;
+
+	/*
+	 * Lazily resolve the RIO base by walking the device tree for the
+	 * pinctrl-rp1 node. Resource 0 is the GPIO block, resource 1 is
+	 * RIO, resource 2 is PADS — see pinctrl-rp1.c probe.
+	 */
+	rp1_gpio_node = of_find_compatible_node(NULL, NULL,
+						"raspberrypi,rp1-gpio");
+	if (!rp1_gpio_node) {
+		dev_warn(dev,
+			 "SANUWAVE: could not find raspberrypi,rp1-gpio node — using per-pin fallback\n");
+		return;
+	}
+
+	ret = of_address_to_resource(rp1_gpio_node, 1, &res);
+	of_node_put(rp1_gpio_node);
+	if (ret) {
+		dev_warn(dev,
+			 "SANUWAVE: could not resolve RP1 RIO resource: %d — using per-pin fallback\n",
+			 ret);
+		return;
+	}
+
+	/*
+	 * Map enough of the RIO region to reach the SET (0x2000) and CLR
+	 * (0x3000) aliases for bank 0 (rio_offset 0x0000).
+	 */
+	cfe->strobe_rio_base = ioremap(res.start + RP1_BANK0_RIO_OFFSET,
+				       RP1_RIO_REGION_SIZE);
+	if (!cfe->strobe_rio_base) {
+		dev_warn(dev,
+			 "SANUWAVE: ioremap of RP1 RIO bank 0 failed — using per-pin fallback\n");
+		return;
+	}
+
+	dev_info(dev,
+		 "SANUWAVE: atomic GPIO write enabled (mask=0x%08x, RIO bank0 phys=0x%llx mapped)\n",
+		 mask, (unsigned long long)(res.start + RP1_BANK0_RIO_OFFSET));
+}
+
+static ssize_t strobe_gpio_store(struct device *dev,
+				 struct device_attribute *attr,
+				 const char *buf, size_t count)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+	char tmp[64];
+	char *p, *token;
+	int gpio_num, i;
+
+	if (count >= sizeof(tmp))
+		return -EINVAL;
+	memcpy(tmp, buf, count);
+	tmp[count] = '\0';
+
+	/* Writing "-1" releases all GPIOs */
+	if (tmp[0] == '-') {
+		for (i = 0; i < cfe->strobe_gpio_count; i++) {
+			gpio_free(cfe->strobe_gpios[i]);
+			cfe->strobe_gpios[i] = -1;
+		}
+		cfe->strobe_gpio_count = 0;
+		cfe->strobe_set_mask = 0;
+		dev_info(dev, "SANUWAVE: strobe GPIOs released\n");
+		return count;
+	}
+
+	/* Release any previously held GPIOs */
+	for (i = 0; i < cfe->strobe_gpio_count; i++) {
+		gpio_free(cfe->strobe_gpios[i]);
+		cfe->strobe_gpios[i] = -1;
+	}
+	cfe->strobe_gpio_count = 0;
+	cfe->strobe_set_mask = 0;
+
+	/* Parse comma-separated GPIO numbers: "17,6,24,7" */
+	p = tmp;
+	while ((token = strsep(&p, ",")) != NULL) {
+		if (cfe->strobe_gpio_count >= 8)
+			break;
+		if (kstrtoint(token, 10, &gpio_num) != 0 || gpio_num < 0) {
+			dev_err(dev, "SANUWAVE: invalid GPIO number '%s'\n", token);
+			continue;
+		}
+		if (gpio_request(gpio_num, "sanuwave-strobe") != 0) {
+			dev_err(dev, "SANUWAVE: failed to request GPIO %d\n", gpio_num);
+			continue;
+		}
+		gpio_direction_output(gpio_num, 0);
+		cfe->strobe_gpios[cfe->strobe_gpio_count++] = gpio_num;
+		dev_info(dev, "SANUWAVE: strobe GPIO %d acquired\n", gpio_num);
+	}
+
+	/*
+	 * Build the atomic-write bitmask and ioremap the RIO block if needed.
+	 * gpio_request/gpio_direction_output above set the pad mux to SIO so
+	 * the RIO register has effect; without that, writes to RIO_OUT_SET
+	 * would be ignored by the pad.
+	 */
+	sanuwave_strobe_rebuild_mask(cfe, dev);
+
+	return count;
+}
+
+static ssize_t strobe_gpio_show(struct device *dev,
+				struct device_attribute *attr, char *buf)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+	int len = 0, i;
+
+	for (i = 0; i < cfe->strobe_gpio_count; i++) {
+		if (i > 0)
+			len += scnprintf(buf + len, PAGE_SIZE - len, ",");
+		len += scnprintf(buf + len, PAGE_SIZE - len, "%d",
+				 cfe->strobe_gpios[i]);
+	}
+	len += scnprintf(buf + len, PAGE_SIZE - len, "\n");
+	return len;
+}
+static DEVICE_ATTR_RW(strobe_gpio);
+
+static ssize_t strobe_sequence_store(struct device *dev,
+				     struct device_attribute *attr,
+				     const char *buf, size_t count)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+	int i, len;
+
+	/* Strip trailing newline */
+	len = count;
+	while (len > 0 && (buf[len - 1] == '\n' || buf[len - 1] == '\r'))
+		len--;
+
+	if (len <= 0 || len > 32)
+		return -EINVAL;
+
+	cfe->strobe_seq_len = len;
+	for (i = 0; i < len; i++)
+		cfe->strobe_seq[i] = (buf[i] == '1');
+
+	dev_info(dev, "SANUWAVE: strobe sequence set, %d frames\n", len);
+	return count;
+}
+
+static ssize_t strobe_sequence_show(struct device *dev,
+				    struct device_attribute *attr, char *buf)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+	int i, len = 0;
+
+	for (i = 0; i < cfe->strobe_seq_len; i++)
+		len += scnprintf(buf + len, PAGE_SIZE - len, "%c",
+				 cfe->strobe_seq[i] ? '1' : '0');
+	len += scnprintf(buf + len, PAGE_SIZE - len, "\n");
+	return len;
+}
+static DEVICE_ATTR_RW(strobe_sequence);
+
+static ssize_t strobe_active_store(struct device *dev,
+				   struct device_attribute *attr,
+				   const char *buf, size_t count)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+	int val;
+
+	if (kstrtoint(buf, 10, &val) != 0)
+		return -EINVAL;
+
+	if (val) {
+		if (cfe->strobe_gpio_count == 0) {
+			dev_err(dev, "SANUWAVE: no strobe GPIOs configured\n");
+			return -EINVAL;
+		}
+		if (cfe->strobe_seq_len == 0) {
+			dev_err(dev, "SANUWAVE: no strobe sequence configured\n");
+			return -EINVAL;
+		}
+		/* Ensure all GPIOs start low */
+		sanuwave_strobe_deassert(cfe);
+
+		cfe->strobe_frame_idx = 0;
+		/* Memory barrier to ensure idx/seq visible before active flag */
+		smp_wmb();
+		cfe->strobe_active = true;
+		dev_info(dev, "SANUWAVE: strobe ARMED (%d GPIOs, %d frame sequence, atomic=%s)\n",
+			 cfe->strobe_gpio_count, cfe->strobe_seq_len,
+			 (cfe->strobe_rio_base && cfe->strobe_set_mask) ? "yes" : "no");
+	} else {
+		cfe->strobe_active = false;
+		/* Memory barrier then force GPIOs low */
+		smp_wmb();
+		sanuwave_strobe_deassert(cfe);
+		dev_info(dev, "SANUWAVE: strobe DISARMED\n");
+	}
+
+	return count;
+}
+
+static ssize_t strobe_active_show(struct device *dev,
+				  struct device_attribute *attr, char *buf)
+{
+	struct cfe_device *cfe = dev_get_drvdata(dev);
+
+	return scnprintf(buf, PAGE_SIZE, "%d\n", cfe->strobe_active ? 1 : 0);
+}
+static DEVICE_ATTR_RW(strobe_active);
