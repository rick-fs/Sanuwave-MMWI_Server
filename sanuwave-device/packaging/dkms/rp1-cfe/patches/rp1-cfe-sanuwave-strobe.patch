+/*
+ * SANUWAVE: assert all configured strobe GPIOs simultaneously.
+ *
+ * Uses a single writel() to the RIO SET alias when the fast path is
+ * available (all pins in bank 0, ioremap succeeded). The SET alias performs
+ * an atomic OR — bits set to 1 in the written value become 1 in RIO_OUT,
+ * bits set to 0 are unchanged. Falls back to per-pin gpio_set_value()
+ * otherwise. Inlined and called from ISR context.
+ */
+static inline void sanuwave_strobe_assert(struct cfe_device *cfe)
+{
+	if (cfe->strobe_rio_base && cfe->strobe_set_mask) {
+		writel(cfe->strobe_set_mask,
+		       cfe->strobe_rio_base + RP1_RIO_SET_ALIAS + RP1_RIO_OUT_REG);
+	} else {
+		int g;
+		for (g = 0; g < cfe->strobe_gpio_count; g++)
+			gpio_set_value(cfe->strobe_gpios[g], 1);
+	}
+}
+
+/*
+ * SANUWAVE: de-assert all configured strobe GPIOs simultaneously.
+ *
+ * Uses the RIO CLR alias for atomic bit-clear: bits set to 1 in the written
+ * value become 0 in RIO_OUT, bits set to 0 are unchanged.
+ */
+static inline void sanuwave_strobe_deassert(struct cfe_device *cfe)
+{
+	if (cfe->strobe_rio_base && cfe->strobe_set_mask) {
+		writel(cfe->strobe_set_mask,
+		       cfe->strobe_rio_base + RP1_RIO_CLR_ALIAS + RP1_RIO_OUT_REG);
+	} else {
+		int g;
+		for (g = 0; g < cfe->strobe_gpio_count; g++)
+			gpio_set_value(cfe->strobe_gpios[g], 0);
+	}
+}
