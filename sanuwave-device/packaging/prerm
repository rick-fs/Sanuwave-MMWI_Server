#!/bin/bash
set -e

# Called by dpkg before the package is removed or upgraded.  Remove the
# DKMS registrations so the build artifacts don't linger in
# /var/lib/dkms/ after uninstall.

DW9714_NAME="dw9714"
DW9714_VERSION="1.0"
DW9714_SRC="/usr/src/${DW9714_NAME}-${DW9714_VERSION}"

CFE_NAME="rp1-cfe-sanuwave"
CFE_VERSION="1.0"
CFE_SRC="/usr/src/${CFE_NAME}-${CFE_VERSION}"

CFE_MODPROBE_FILE="/etc/modprobe.d/rp1-cfe-sanuwave.conf"

if command -v dkms > /dev/null 2>&1; then
    if dkms status "${DW9714_NAME}/${DW9714_VERSION}" 2>/dev/null \
           | grep -q "${DW9714_NAME}"; then
        echo "Removing DW9714 DKMS registration..."
        dkms remove "${DW9714_NAME}/${DW9714_VERSION}" --all 2>/dev/null || true
    fi

    if dkms status "${CFE_NAME}/${CFE_VERSION}" 2>/dev/null \
           | grep -q "${CFE_NAME}"; then
        echo "Removing rp1-cfe-sanuwave DKMS registration..."
        dkms remove "${CFE_NAME}/${CFE_VERSION}" --all 2>/dev/null || true
    fi
fi

rm -rf "${DW9714_SRC}"
rm -rf "${CFE_SRC}"
rm -f  "${CFE_MODPROBE_FILE}"

# depmod so the stock rp1-cfe takes over again after our /updates/ copy
# is gone.
depmod -a "$(uname -r)" 2>/dev/null || true

echo ""
echo "  *** The patched rp1-cfe module will remain loaded until reboot. ***"
echo "  *** Reboot to return to the stock kernel driver.                ***"
echo ""

exit 0
