#!/bin/bash
set -e

[[ -n "$DEBUG" ]] && set -x

log() {
    echo "[sanuwave-client] $*"
}

case "$1" in
    configure)
        log "Configuring Sanuwave Client..."
        
        if command -v gtk-update-icon-cache > /dev/null 2>&1; then
            log "Updating icon cache..."
            gtk-update-icon-cache -f -t /usr/share/icons/hicolor 2>/dev/null || true
        fi
        
        if command -v update-desktop-database > /dev/null 2>&1; then
            log "Updating desktop database..."
            update-desktop-database /usr/share/applications 2>/dev/null || true
        fi
        
        log "Updating library cache..."
        ldconfig
        
        log "Installation complete."
        echo ""
        echo "======================================"
        echo "  Sanuwave Client installed to /usr/bin/SanuwaveClient"
        echo ""
        echo "  Run from terminal: SanuwaveClient"
        echo "  Or launch from applications menu"
        echo "======================================"
        ;;
        
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
        
    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac



exit 0
